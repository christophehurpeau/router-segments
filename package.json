{
  "name": "router-segments",
  "version": "12.1.2",
  "description": "Router with segments",
  "keywords": [
    "router",
    "segments"
  ],
  "homepage": "https://christophehurpeau.github.io/router-segments/",
  "bugs": {
    "url": "https://github.com/christophehurpeau/router-segments/issues"
  },
  "license": "MIT",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (http://christophe.hurpeau.com/)",
  "repository": "https://github.com/christophehurpeau/router-segments.git",
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index-node.mjs",
  "types": "./dist/definitions/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/definitions/index.d.ts",
      "node": {
        "import": "./dist/index-node.mjs"
      }
    }
  },
  "scripts": {
    "build": "yarn clean:build && rollup --config rollup.config.mjs && yarn run build:definitions",
    "build:definitions": "tsc -p tsconfig.json",
    "checks": "node scripts/check-package.js",
    "clean": "yarn clean:build",
    "clean:build": "pob-esbuild-clean-out dist",
    "format": "oxfmt",
    "format:check": "oxfmt --check .",
    "generate:api": "typedoc --tsconfig tsconfig.doc.json",
    "generate:test-coverage": "rm -Rf docs/coverage/ ; NODE_ENV=production BABEL_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --coverage --coverageReporters=pob-lcov-reporter --coverageDirectory=docs/coverage/",
    "lint": "yarn run format && tsc && yarn run lint:eslint",
    "lint:eslint": "eslint --quiet .",
    "postinstall": "pob-root-postinstall",
    "postpack": "pinst --enable",
    "prepack": "pinst --disable",
    "test": "TZ=UTC vitest",
    "test:coverage": "TZ=UTC POB_VITEST_COVERAGE=json,text vitest run --coverage",
    "test:coverage:json": "TZ=UTC POB_VITEST_COVERAGE=json vitest run --coverage",
    "test:watch": "TZ=UTC vitest --watch",
    "watch": "yarn clean:build && rollup --config rollup.config.mjs --watch"
  },
  "dependencies": {
    "nightingale-logger": "^18.1.0",
    "path-to-regexp": "^8.4.2"
  },
  "devDependencies": {
    "@pob/eslint-config": "65.4.3",
    "@pob/rollup-esbuild": "9.1.0",
    "@pob/root": "24.0.0",
    "@types/node": "22.19.3",
    "@vitest/coverage-v8": "4.1.7",
    "check-package-dependencies": "11.1.1",
    "eslint": "10.4.0",
    "pinst": "3.0.0",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  },
  "commitlint": {
    "extends": [
      "@pob/root/commitlint-config"
    ]
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "yarn@4.15.0",
  "pob": {
    "bundler": "rollup-esbuild",
    "entries": [
      "index"
    ],
    "envs": [
      {
        "target": "node",
        "version": "22",
        "omitVersionInFileName": true
      }
    ],
    "typescript": true
  }
}
